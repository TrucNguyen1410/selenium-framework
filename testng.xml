<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="Automation Suite" verbose="1" parallel="methods" thread-count="3">
    <!-- Cấu hình Listeners để tự động áp dụng việc chạy lại các test bị lỗi -->
    <listeners>
        <listener class-name="framework.utils.RetryAnalyzer$RetryListener"/>
    </listeners>
    
    <test name="Login Tests">
        <!-- Tham số cấu hình gửi vào BaseTest -->
        <parameter name="browser" value="chrome"/>
        <parameter name="env" value="dev"/>
        
        <classes>
            <class name="tests.LoginTest"/>
        </classes>
    </test>
</suite>